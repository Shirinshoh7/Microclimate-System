# MicroClimate AI Pro Backend - Environment Configuration
# Copy this file to .env and fill in with your actual credentials

# ============================================================================
# MQTT Broker Configuration (HiveMQ Cloud or self-hosted)
# ============================================================================
MQTT_HOST=your-hivemq-instance.cloud.mosquitto.org
MQTT_PORT=8883
MQTT_USER=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password_here
MQTT_TOPIC=iot/microclimate/+

# ============================================================================
# Server Configuration
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Enable debug mode (set to False in production)
DEBUG=False

# ============================================================================
# Application Metadata
# ============================================================================
APP_NAME=MicroClimate AI Pro Backend
APP_VERSION=2.1.0

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iot_diplom
DB_USER=postgres
DB_PASSWORD=change_this_to_a_secure_password

# ============================================================================
# JWT Authentication
# ============================================================================
# IMPORTANT: Generate a strong random secret key
# Min 32 bytes recommended. Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_very_secure_random_secret_key_change_this_in_production
JWT_ALGORITHM=HS256

# Token expiration in minutes
# Default: 10080 = 7 days
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================================================
# Firebase Cloud Messaging (FCM) - Push Notifications
# ============================================================================
# Set to True to enable push notifications to mobile apps
FCM_ENABLED=False

# Path to Firebase Admin SDK JSON credentials file
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=./microclamite-firebase-adminsdk-fbsvc.json

# Interval (seconds) between danger reminder notifications
FCM_DANGER_REMINDER_SEC=300

# Default user ID for testing notifications
FCM_DEFAULT_USER_ID=user_1

# ============================================================================
# CORS - Cross-Origin Resource Sharing
# ============================================================================
# Allow requests from these origins
# DEV: "*" allows all origins
# PROD: Restrict to whitelisted domains only
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
